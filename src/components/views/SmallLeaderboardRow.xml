<component name="SmallLeaderboardRow"
           extends="Group"
           >
  <interface>
    <field id="golfer"
           type="assocarray"
           />

  </interface>
  <children>
    <LayoutGroup layoutDirection="horiz">
      <Rectangle width="5" />
      <SimpleLabel id="place"
                   color="#138A60"
                   fontWeight="bold"
                   fontSize="20"
                   width="30"
                   />
      <SimpleLabel id="name"
                   width="150"
                   color="#1C1E1F"
                   fontSize="20"
                   fontWeight="bold"
                   />
      <Rectangle width="5" />
      <SimpleLabel id="score"
                   fontWeight="bold"
                   width="30"
                   horizAlign="center"
                   color="#1C1E1F"
                   fontSize="20"
                   />
      <Rectangle width="9" />
      <Rectangle width="28"
                 height="28"
                 color="#00000000"
                 >

        <SimpleLabel id="teetime"
                     color="#1C1E1F"
                     horizAlign="center"
                     vertAlign="center"
                     fontWeight="regular"
                     fontSize="10"
                     height="28"
                     />
        <SimpleLabel id="thru"
                     color="#1C1E1F"
                     horizAlign="center"
                     width="14"
                     fontWeight="bold"
                     fontSize="20"
                     />
        <SimpleLabel id="thru2"
                     translation="[14, 0]"
                     horizAlign="center"
                     color="#1C1E1F"
                     width="14"
                     fontWeight="bold"
                     fontSize="20"
                     />
      </Rectangle>
      <Rectangle width="5" />

    </LayoutGroup>
  </children>
</component>