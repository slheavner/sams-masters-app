                    translation="[0, 100]"
                    focusBitmapUri="pkg:"
                    itemSize="[736, 50]"
                    numRows="18"
                    drawFocusFeedback="false"
                    vertFocusAnimationStyle="floatingFocus"
                    itemComponentName="VideoLeaderboardRow"
                    />
